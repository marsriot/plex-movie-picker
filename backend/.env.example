# Copy this file to ".env" and fill in your values.

# Your Plex server URL. Usually http://localhost:32400 if the app runs on the
# same machine as Plex, or http://<plex-machine-ip>:32400 otherwise.
PLEX_URL=http://localhost:32400

# Your Plex auth token. See README for how to find it.
PLEX_TOKEN=

# Name of your movie library section in Plex (as it appears in the Plex UI).
PLEX_MOVIE_LIBRARY=Movies

# Anthropic API key for the mood-based picking feature (added later).
ANTHROPIC_API_KEY=

# Where to store the local SQLite cache. Relative to the backend/ folder.
DB_PATH=moviepicker.db
